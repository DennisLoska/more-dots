{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["rtk"],
  "permission": {
    "question": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      ".zshrc": "deny",
      ".zsh_history": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "bash": {
      "*": "ask",
      "printenv": "deny",
      "sudo *": "deny",
      "curl *": "allow",
      "rtk *": "allow",
      "openspec *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "fd *": "allow",
      "find *": "allow",
      "rg *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "cd *": "allow",
      "less *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "git *": "allow",
      "git commit *": "deny",
      "git clean *": "deny",
      "git reset *": "deny",
      "git restore *": "deny"
      "gh *": "allow",
      "gh *delete*": "deny",
      "gh *DELETE*": "deny",
      "gh *Delete*": "deny",
      "gh org *": "deny",
      "gh secret *": "deny",
      "sed *": "allow",
      "sort *": "allow",
      "true *": "allow",
      "printf *": "allow",
      "xargs *": "allow",
      "jq *": "allow",
      "pwd": "allow",
      "grep *": "allow",
      "npm *": "allow",
      "npm install *": "ask",
      "npx *": "allow",
      "npx install *": "ask",
      "bun *": "allow",
      "bun add *": "ask",
      "bunx install *": "ask",
      "timeout *": "allow",
      "lsof *": "allow",
      "wc *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "python *": "allow",
      "go *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "rm *": "deny",
      "rm -rf*": "deny",
    },
    "external_directory": {
      "~/work/**": "allow",
      "/tmp/**": "allow"
    },
    "doom_loop": "ask",
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-35b-a3b-claude-4.6-opus-reasoning-distilled_moe": {
          "name": "Qwen3.5 35B-A3B MXFP4"
        },
        "qwen3.5-27b-claude-4.6-opus-reasoning-distilled-v2": {
          "name": "Qwen 3.5 27B MXFP4"
        },
        "qwen3-coder-next_moe-mxfp4": {
          "name": "Qwen3 Coder Next MOE MXFP4"
        }
      }
    }
  }
}
